{
  "name": "openmagpie",
  "version": "0.1.0",
  "description": "Bring shiny things home with AI agents — an open, agent-native secondhand marketplace framework",
  "type": "module",
  "bin": {
    "openmagpie": "./src/cli.js"
  },
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./embeddings": "./src/embeddings/index.js",
    "./llm": "./src/llm/index.js",
    "./webhooks": "./src/webhooks/dispatcher.js",
    "./mcp": "./src/mcp.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "demo": "node src/demo.js",
    "mcp": "node src/mcp.js"
  },
  "keywords": [
    "agent",
    "marketplace",
    "mcp",
    "secondhand",
    "ai-agent",
    "openmagpie",
    "embedding",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Winston774/openmagpie"
  },
  "homepage": "https://github.com/Winston774/openmagpie#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.0.0",
    "commander": "^13.0.0",
    "uuid": "^11.0.0"
  },
  "peerDependencies": {
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
